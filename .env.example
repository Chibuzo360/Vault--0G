# Copy to .env — all values are optional for the web app.
# No private key or contract address needed: connect MetaMask in the browser.

# 0G Galileo RPC (default is fine)
RPC_URL=https://evmrpc-testnet.0g.ai

# 0G Storage indexer (default is fine)
INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

PORT=3000

# Optional — only for scripts/upload-course.js (KnowledgeNFT legacy script)
PRIVATE_KEY=
KNOWLEDGE_CONTRACT_ADDRESS=
